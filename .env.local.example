# Copy this file to .env.local and fill in your keys.
# All keys are read ONLY on the server — they never reach the browser.

# Anthropic (required) — AUGUST's brain.
ANTHROPIC_API_KEY=

# ElevenLabs (optional) — premium voice. Without these, AUGUST uses the browser voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Upstash Redis (optional) — persistent memory. Without these, memory is disabled.
# Create a free database at https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# FRED (optional, FREE key) — Markets macro gauges (10Y-2Y spread, financial stress).
# Without it those two gauges show "needs FRED key". Free key:
# https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# OpenSky (optional, FREE) — densifies the Command globe's flight layer. Without it,
# flights are anonymous (sparser, rate-limited). OAuth2 client credentials from
# https://opensky-network.org (Account -> API Client).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
