# Copy this file to .env.local and fill in your keys.
# All keys are read ONLY on the server — they never reach the browser.

# Anthropic (required) — AUGUST's brain.
ANTHROPIC_API_KEY=

# ElevenLabs (optional) — premium voice. Without these, AUGUST uses the browser voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Deepgram (optional, recommended) — streaming speech-to-text for hands-free voice
# mode. Without it, voice falls back to the browser's Web Speech API (flaky on
# desktop, effectively dead on iOS). The raw key stays server-side; the browser
# only ever receives a short-lived grant token from /api/deepgram-token. Free
# credits cover personal use. Create a key at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Upstash Redis (optional) — persistent memory. Without these, memory is disabled.
# Create a free database at https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# FRED (optional, FREE key) — Markets macro gauges (10Y-2Y spread, financial stress).
# Without it those two gauges show "needs FRED key". Free key:
# https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# OpenSky (optional, FREE) — densifies the Command globe's flight layer. Without it,
# flights are anonymous (sparser, rate-limited). OAuth2 client credentials from
# https://opensky-network.org (Account -> API Client).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Google OAuth (optional) — Comms reads your Gmail and Presence/Brief read your
# Calendar, both READ-ONLY, via ONE OAuth client. Without these, Comms shows "not
# configured" and the Day line stays hidden. Create an OAuth 2.0 Client (type: Web
# application) at https://console.cloud.google.com/apis/credentials and ENABLE BOTH
# the Gmail API AND the Google Calendar API on the project (Calendar is separate —
# without it you get 403 accessNotConfigured). Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/google/callback   (local dev)
#   https://YOUR-VERCEL-DOMAIN/api/auth/google/callback   (production)
# Requires UPSTASH_* above for token storage. Scopes: gmail.readonly +
# calendar.events.readonly + gmail.send (least-privilege; send is send-only and never
# weakens read). AUGUST can DRAFT replies; nothing sends without your explicit tap on
# the final text. If you connected before a scope was added, RECONNECT once to grant
# it (incremental consent). gmail.send is a "sensitive" scope (lighter verification).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App origin (recommended in production) — the canonical https origin, e.g.
# https://august.example.com . The OAuth redirect_uri and the post-login redirect
# are pinned to this so a forged Host header can't cause an open redirect. On
# Vercel this is auto-derived from VERCEL_PROJECT_PRODUCTION_URL if unset. Leave
# blank for local dev (localhost is always trusted).
APP_ORIGIN=

# Web Push (optional) — installable PWA notifications (the spine for off-screen
# Morning Brief / Watchers). Generate a VAPID keypair once with:
#   npx web-push generate-vapid-keys
# The PRIVATE key is server-only; the PUBLIC key is also exposed to the client via
# NEXT_PUBLIC_VAPID_PUBLIC_KEY (set it to the SAME value as VAPID_PUBLIC_KEY).
# VAPID_SUBJECT must be a mailto: or https: URL. PUSH_SEND_SECRET (any long random
# string) guards /api/push/send. Requires UPSTASH_* for the subscription store.
# iOS note: web push only works once AUGUST is INSTALLED to the home screen (iOS 16.4+).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
PUSH_SEND_SECRET=

# Cron secret (REQUIRED in production for the daily auto-brief) — protects the
# Morning Brief compile endpoint (/api/cron/brief) so only Vercel's scheduler can
# trigger the token-spending compile. When set, Vercel automatically sends
# `Authorization: Bearer <CRON_SECRET>` on the scheduled request and the route
# rejects anything else. If it is UNSET in production the scheduled compile is
# disabled (returns 503) — by design, so the endpoint is never left open; the
# in-app "Brief me" button still compiles on demand. Generate any long random
# string. Schedule lives in vercel.json (0 10 UTC = ~6 AM ET; Vercel Cron is
# UTC-only and does not follow DST). Requires UPSTASH_* for the day-cache.
# The SAME CRON_SECRET also protects /api/cron/intel (Market Intel discovery + brief).
#
# The SAME CRON_SECRET also protects /api/cron/watchers (the standing-alerts check).
# Point an external pinger (QStash, cron-job.org, or a Vercel Cron entry) at it every
# ~15 min, sending `Authorization: Bearer <CRON_SECRET>`. It's a cheap no-op when no
# watcher trips (and overnight during quiet hours), and fires push via the VAPID setup
# above. Requires UPSTASH_* (watcher records) + VAPID_* (to actually notify).
#
# The SAME CRON_SECRET also protects /api/cron/intel-track (the Idea Tracker snapshot
# pass). Point a pinger at it every ~10-15 min during market hours: it ingests the
# latest brief's ideas, batches quotes, evaluates honest lifecycle transitions
# (ARMED→TRIGGERED→TARGET_HIT/INVALIDATED), and records bounded snapshots + MFE/MAE.
# Idempotent — double pings are no-ops. The board also runs a throttled evaluation
# on page load, so the tracker works (more coarsely) before any schedule is wired.
CRON_SECRET=

# OPTIONAL — Idea Tracker staleness horizon in days (default 5). A tracked idea
# whose source hasn't re-mentioned it within this window is visibly marked STALE
# (never deleted).
TRACKER_STALE_DAYS=

# ── MARKET INTEL (the /intel feature) ──────────────────────────────────────
# MANDATORY for the MVP: ANTHROPIC_API_KEY (above — extraction + briefs) and the
# UPSTASH_* pair (above — stores sources/videos/analyses/briefs). With just those,
# the manual-transcript flow works end-to-end today: add a video URL, paste its
# transcript, and AUGUST produces cited, structured intel + a nightly brief.
#
# OPTIONAL — YouTube Data API v3 key. Enables channel AUTO-discovery (uploads
# playlist), live/upcoming status, video duration, and description chapters. Without
# it you add videos by URL (keyless oEmbed metadata) and paste transcripts manually.
# Create at https://console.cloud.google.com → APIs & Services → Enable "YouTube Data
# API v3" → Credentials → API key. Server-side only.
YOUTUBE_API_KEY=
#
# OPTIONAL — external transcript provider for caption-less videos (public
# captions via timedtext are tried first, free). Implemented adapter:
# Supadata (https://supadata.ai — verified docs at docs.supadata.ai). Sign up,
# create an API key, set it here. The pipeline then auto-fetches transcripts
# for discovered videos: discover → transcript → chapters → extract → board.
# Statuses stay truthful (unavailable / permission_required / provider_error /
# not_configured) and manual paste remains first-class.
TRANSCRIPT_PROVIDER_API_KEY=
# OPTIONAL — adapter selector; "supadata" (default) is the implemented one.
# An unrecognized value reports not_configured rather than guessing an API.
TRANSCRIPT_PROVIDER=
#
# OPTIONAL — Finnhub API key (free tier is plenty). Powers ONLY the /intel
# CATALYSTS line: verified earnings dates for your tracked watchlist over the
# next ~7 sessions (one cached range call per 6h). Unset → the line is hidden
# entirely; nothing else depends on it. Server-side only. Free key:
# https://finnhub.io/dashboard
FINNHUB_API_KEY=
